# Example environment variables for Ripple v2
# Copy this file to .env and fill with your real values before running in development.

# Server
NODE_ENV=development
PORT=3000

# Supabase Auth (Project Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_your_secret_key_here
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key_here
# Supabase user id (UUID) that should get the "admin" role. Leave blank until
# you've signed up once and can copy your own user id from the dashboard.
OWNER_OPEN_ID=

# Set to "true" only once real Stripe keys/prices below are configured.
# Anything else (including unset) keeps checkout disabled with a friendly
# "coming soon" state on the frontend and a hard block on the backend.
PAYMENTS_ENABLED=false

# Stripe (secret key + Price IDs) — placeholders are fine while PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PRICE_PRO_MONTHLY=price_XXXXXXXXXXXX
STRIPE_PRICE_PRO_ANNUAL=price_XXXXXXXXXXXX
STRIPE_PRICE_PREMIER_MONTHLY=price_XXXXXXXXXXXX
STRIPE_PRICE_PREMIER_ANNUAL=price_XXXXXXXXXXXX

# Cloudflare Web Analytics beacon token (Cloudflare dashboard -> Analytics &
# Logs -> Web Analytics -> your site -> "Beacon token" JSON). Cookie-less,
# no personal data collected. Leave blank to disable — public tool pages
# render the same either way, just without the beacon script.
VITE_CF_BEACON_TOKEN=

# Google Search Console HTML-tag verification (Settings -> Ownership
# verification -> HTML tag -> copy the content="..." value). Leave blank
# until verification is started; empty means no meta tag is rendered.
VITE_GOOGLE_SITE_VERIFICATION=
